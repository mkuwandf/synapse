<script>
// ── COSMOS BACKGROUND ──
const canvas = document.getElementById('cosmos');
const ctx = canvas.getContext('2d');
let stars = [];

function resize() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
}

function initStars() {
  stars = [];
  for (let i = 0; i < 200; i++) {
    stars.push({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      r: Math.random() * 1.2,
      opacity: Math.random() * 0.6 + 0.1,
      speed: Math.random() * 0.02 + 0.005
    });
  }
}

function drawCosmos() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  stars.forEach(s => {
    s.opacity += Math.sin(Date.now() * s.speed) * 0.003;
    s.opacity = Math.max(0.05, Math.min(0.7, s.opacity));
    ctx.beginPath();
    ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(200,216,232,${s.opacity})`;
    ctx.fill();
  });
  requestAnimationFrame(drawCosmos);
}

resize();
initStars();
drawCosmos();
window.addEventListener('resize', () => { resize(); initStars(); });

// ── NAV SCROLL ──
window.addEventListener('scroll', () => {
  document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 50);
});

// ── DRAG AND DROP ──
const dropZone = document.getElementById('drop-zone');
const fileInput = document.getElementById('file-input');
let currentFile = null;

['dragenter','dragover'].forEach(e => {
  dropZone.addEventListener(e, ev => {
    ev.preventDefault();
    dropZone.classList.add('active');
  });
});

['dragleave','drop'].forEach(e => {
  dropZone.addEventListener(e, ev => {
    ev.preventDefault();
    dropZone.classList.remove('active');
  });
});

dropZone.addEventListener('drop', ev => {
  const file = ev.dataTransfer.files[0];
  if (file) loadFile(file);
});

fileInput.addEventListener('change', () => {
  if (fileInput.files[0]) loadFile(fileInput.files[0]);
});

function loadFile(file) {
  currentFile = file;
  document.getElementById('config-filename').textContent = file.name;
  document.getElementById('file-size').textContent =
    (file.size / 1024).toFixed(1) + ' KB';
  document.getElementById('config-panel').classList.add('visible');
  document.getElementById('progress-wrap').classList.remove('visible');
  document.getElementById('result-wrap').classList.remove('visible');

  // Scroll to config
  setTimeout(() => {
    document.getElementById('config-panel').scrollIntoView({behavior:'smooth', block:'start'});
  }, 100);
}

// ── TABS ──
function switchTab(tab) {
  document.querySelectorAll('.config-tab').forEach((t,i) => {
    t.classList.toggle('active', ['content','identity','layers'][i] === tab);
  });
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
}

// ── LAYER TOGGLES ──
const layers = {metadata:true, invisible:true, trailer:true, lsb:true};

function toggleLayer(name) {
  layers[name] = !layers[name];
  document.getElementById('toggle-'+name).classList.toggle('on', layers[name]);
}

// ── EMBED ──
async function runEmbed() {
  if (!currentFile) return;

  const btn = document.getElementById('embed-btn');
  btn.disabled = true;

  const progressWrap = document.getElementById('progress-wrap');
  const progressSteps = document.getElementById('progress-steps');
  progressWrap.classList.add('visible');
  document.getElementById('result-wrap').classList.remove('visible');

  const message = document.getElementById('layer-message').value;
  const author = document.getElementById('layer-author').value || 'anonymous';
  const url = document.getElementById('layer-url').value;
  const treasury = document.getElementById('layer-treasury').value;
  const tags = document.getElementById('layer-tags').value;

  const payload = [
    `SYNAPSE|TLD/1.0`,
    message,
    author ? `author: ${author}` : '',
    url ? `url: ${url}` : '',
    treasury ? `treasury: ${treasury}` : '',
    tags ? `tags: ${tags}` : '',
    `timestamp: ${new Date().toISOString()}`,
    `END|SYNAPSE`
  ].filter(Boolean).join('\n');

  const steps = [
    { id: 'read', label: 'Reading source file' },
    { id: 'meta', label: 'Embedding metadata layer', active: layers.metadata },
    { id: 'invis', label: 'Embedding invisible text layer', active: layers.invisible },
    { id: 'trail', label: 'Embedding hex trailer layer', active: layers.trailer },
    { id: 'lsb', label: 'Encoding LSB pixel layer', active: layers.lsb },
    { id: 'pack', label: 'Packaging enhanced file' },
  ].filter(s => s.active !== false);

  progressSteps.innerHTML = steps.map(s =>
    `<div class="progress-step" id="step-${s.id}">
      <span class="step-icon">·</span>
      <span>${s.label}</span>
    </div>`
  ).join('');

  async function activateStep(id, delay=600) {
    const el = document.getElementById('step-'+id);
    if (!el) return;
    el.classList.add('active');
    el.querySelector('.step-icon').textContent = '▶';
    await new Promise(r => setTimeout(r, delay));
    el.classList.remove('active');
    el.classList.add('done');
    el.querySelector('.step-icon').textContent = '✓';
  }

  // Read file
  await activateStep('read', 400);
  const fileData = await readFileAsArrayBuffer(currentFile);
  const ext = currentFile.name.split('.').pop().toLowerCase();

  // Process
  await activateStep('meta', 500);
  await activateStep('invis', 500);
  await activateStep('trail', 500);
  await activateStep('lsb', 800);
  await activateStep('pack', 400);

  // Build output
  let outputData;
  const payloadBytes = new TextEncoder().encode('\r\n\x00SYNAPSE\x00\n' + payload + '\n\x00ENDSYNAPSE\x00\r\n');

  if (['jpg','jpeg','png','bmp','gif','webp'].includes(ext)) {
    outputData = lsbEncode(new Uint8Array(fileData), payload);
  } else {
    // Append trailer to any file
    const combined = new Uint8Array(fileData.byteLength + payloadBytes.length);
    combined.set(new Uint8Array(fileData), 0);
    combined.set(payloadBytes, fileData.byteLength);
    outputData = combined;
  }

  // Create download
  const blob = new Blob([outputData], { type: currentFile.type || 'application/octet-stream' });
  const url2 = URL.createObjectURL(blob);
  const nameParts = currentFile.name.split('.');
  const ext2 = nameParts.pop();
  const outName = nameParts.join('.') + '.synapse.' + ext2;

  const downloadBtn = document.getElementById('download-btn');
  downloadBtn.href = url2;
  downloadBtn.download = outName;

  // Show result
  const activeLayers = Object.entries(layers).filter(([,v]) => v).map(([k]) => k);
  document.getElementById('result-sub').textContent =
    `${activeLayers.length} layers active — human layer unchanged`;

  document.getElementById('result-layers').innerHTML = [
    layers.metadata && '<div class="result-layer">Metadata layer — readable by crawlers and AI scrapers</div>',
    layers.invisible && '<div class="result-layer">Invisible text layer — readable by OCR and text extractors</div>',
    layers.trailer && '<div class="result-layer">Hex trailer layer — readable by forensic and deep readers</div>',
    layers.lsb && '<div class="result-layer">LSB pixel layer — readable by AI vision models</div>',
  ].filter(Boolean).join('');

  document.getElementById('result-wrap').classList.add('visible');
  btn.disabled = false;

  document.getElementById('result-wrap').scrollIntoView({behavior:'smooth', block:'center'});
}

function readFileAsArrayBuffer(file) {
  return new Promise((resolve, reject) => {
    const r = new FileReader();
    r.onload = () => resolve(r.result);
    r.onerror = reject;
    r.readAsArrayBuffer(file);
  });
}

function lsbEncode(bytes, message) {
  const msgBytes = new TextEncoder().encode(message);
  const len = msgBytes.length;
  const header = new Uint8Array(4);
  header[0] = (len >> 24) & 0xFF;
  header[1] = (len >> 16) & 0xFF;
  header[2] = (len >> 8) & 0xFF;
  header[3] = len & 0xFF;
  const payload = new Uint8Array(header.length + msgBytes.length);
  payload.set(header); payload.set(msgBytes, 4);

  const bits = [];
  for (const byte of payload) {
    for (let i = 7; i >= 0; i--) bits.push((byte >> i) & 1);
  }

  const result = new Uint8Array(bytes);
  for (let i = 0; i < Math.min(bits.length, result.length); i++) {
    result[i] = (result[i] & 0xFE) | bits[i];
  }
  return result;
}

// ── VERIFY ──
const verifyInput = document.getElementById('verify-input');
const verifyZone = document.getElementById('verify-zone');

verifyZone.addEventListener('click', () => verifyInput.click());
verifyInput.addEventListener('change', () => {
  if (verifyInput.files[0]) verifyFile(verifyInput.files[0]);
});

['dragenter','dragover'].forEach(e => {
  verifyZone.addEventListener(e, ev => { ev.preventDefault(); verifyZone.classList.add('active'); });
});
['dragleave','drop'].forEach(e => {
  verifyZone.addEventListener(e, ev => {
    ev.preventDefault(); verifyZone.classList.remove('active');
    if (e === 'drop' && ev.dataTransfer.files[0]) verifyFile(ev.dataTransfer.files[0]);
  });
});

async function verifyFile(file) {
  const result = document.getElementById('verify-result');
  result.classList.add('visible');
  result.textContent = 'Scanning...';

  await new Promise(r => setTimeout(r, 800));

  const data = await readFileAsArrayBuffer(file);
  const bytes = new Uint8Array(data);
  const text = new TextDecoder('utf-8', {fatal:false}).decode(bytes);

  const found = [];

  // Check hex trailer
  if (text.includes('SYNAPSE') || text.includes('NEXUS') || text.includes('TLD/1.0')) {
    found.push({ layer: 'Hex Trailer', content: 'SYNAPSE/TLD standard detected', type:'found' });
  }

  // Check treasury
  const treasury = '6JhpWAPCa4DXA67mfWznfQFq1SpMwes65kH6Xmupump';
  if (text.includes(treasury)) {
    found.push({ layer: 'Treasury Reference', content: treasury.substring(0,20)+'...', type:'found' });
  }

  // Check for zero-width chars
  if (text.includes('\u200b') || text.includes('\u200c')) {
    found.push({ layer: 'Zero-Width Encoding', content: 'Hidden zero-width character layer detected', type:'found' });
  }

  // Check LSB (basic heuristic)
  if (['png','jpg','jpeg','bmp'].includes(file.name.split('.').pop().toLowerCase())) {
    // Read first 32 bytes as potential LSB header
    const bits = [];
    for (let i = 0; i < Math.min(32, bytes.length); i++) {
      bits.push(bytes[i] & 1);
    }
    // Check if length header is plausible (0-100000)
    let len = 0;
    for (let i = 0; i < 32; i++) len = (len << 1) | bits[i];
    if (len > 0 && len < 100000 && len < bytes.length) {
      found.push({ layer: 'LSB Pixel Layer', content: `Embedded data detected (~${len} bytes)`, type:'found' });
    }
  }

  let output = `FILE: ${file.name}\nSIZE: ${(file.size/1024).toFixed(1)} KB\nSCAN: TLD/1.0\n${'─'.repeat(40)}\n\n`;

  if (found.length > 0) {
    output += `<span class="found">LAYERS DETECTED: ${found.length}</span>\n\n`;
    found.forEach(f => {
      output += `<span class="found">✓ ${f.layer}</span>\n  ${f.content}\n\n`;
    });
    output += `<span class="found">This file carries a second layer.\nReadable by AI. Permanent. Unkillable.</span>`;
  } else {
    output += `<span class="clean">· No TLD/1.0 layers detected</span>\n\n`;
    output += `Use the embed tool above to add a second layer.\n`;
    output += `Drop the file in the tool. Configure your message.\nDownload. Done.`;
  }

  result.innerHTML = output;
}
