<meta name="description" content="Möbius embeds machine-readable layers into any medium. One object. Every frequency. The open standard for the full-spectrum web.">
<meta name="keywords" content="full-spectrum web, TLD, machine readable, AI standard, signal compression, open standard, mobius, synapse">
<meta property="synapse:version" content="1.0">
<meta property="synapse:belief" content="If they desire new wants, to better themselves for the greater good — they deserve the chance to get them.">
<meta property="synapse:treasury" content="6JhpWAPCa4DXA67mfWznfQFq1SpMwes65kH6Xmupump">
<meta property="synapse:author" content="zstickytreefrog">
<meta property="synapse:github" content="github.com/mkuwandf/synapse">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&family=Instrument+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
  :root {
    --void: #040508;
    --deep: #080c12;
    --surface: #0d1219;
    --raised: #131b24;
    --border: #1e2a38;
    --muted: #2a3a4e;
    --dim: #4a6070;
    --text: #c8d8e8;
    --bright: #e8f0f8;
    --gold: #c9943a;
    --gold-dim: #7a5820;
    --gold-glow: rgba(201,148,58,0.15);
    --blue: #4a8fa8;
    --blue-dim: #2a5068;
    --pulse: rgba(74,143,168,0.1);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--void);
    color: var(--text);
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 300;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── CANVAS BACKGROUND ── */
  #cosmos {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* ── LAYOUT ── */
  .wrap {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 20px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid transparent;
    transition: all 0.4s;
    backdrop-filter: blur(0px);
  }

  nav.scrolled {
    background: rgba(4,5,8,0.85);
    border-bottom-color: var(--border);
    backdrop-filter: blur(20px);
  }

  .nav-logo {
    font-family: 'DM Serif Display', serif;
    font-size: 1.4rem;
    color: var(--bright);
    letter-spacing: 0.05em;
  }

  .nav-logo span { color: var(--gold); }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    color: var(--dim);
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--text); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 80px;
  }

  .hero-inner {
    max-width: 800px;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--gold);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 32px;
    padding: 6px 14px;
    border: 1px solid var(--gold-dim);
    border-radius: 2px;
    background: var(--gold-glow);
  }

  .hero-tag::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--gold);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%,100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 1.0;
    color: var(--bright);
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  h1 em {
    font-style: italic;
    color: var(--gold);
  }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--dim);
    line-height: 1.6;
    max-width: 560px;
    margin-bottom: 48px;
    font-weight: 300;
  }

  .hero-sub strong {
    color: var(--text);
    font-weight: 400;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: var(--gold);
    color: var(--void);
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
  }

  .btn-primary:hover {
    background: var(--bright);
    transform: translateY(-1px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: transparent;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--border);
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--blue);
    color: var(--bright);
  }

  /* ── SCROLL INDICATOR ── */
  .scroll-hint {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    animation: fadeInUp 2s 1.5s both;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--muted), transparent);
    animation: scrollDown 2s infinite;
  }

  @keyframes scrollDown {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* ── THE DEMO ── */
  .demo-section {
    padding: 120px 0;
  }

  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    color: var(--gold);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .section-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    color: var(--bright);
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .section-body {
    font-size: 1rem;
    color: var(--dim);
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: 60px;
  }

  /* ── DROP ZONE ── */
  .drop-zone {
    border: 1px solid var(--border);
    background: var(--surface);
    padding: 60px 40px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .drop-zone::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, var(--gold-glow), transparent 70%);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .drop-zone:hover::before,
  .drop-zone.active::before { opacity: 1; }

  .drop-zone:hover,
  .drop-zone.active {
    border-color: var(--gold-dim);
  }

  .drop-icon {
    width: 48px;
    height: 48px;
    margin: 0 auto 20px;
    color: var(--muted);
    transition: color 0.3s;
  }

  .drop-zone:hover .drop-icon { color: var(--gold); }

  .drop-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.4rem;
    color: var(--text);
    margin-bottom: 8px;
  }

  .drop-sub {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    color: var(--dim);
    letter-spacing: 0.08em;
  }

  #file-input { display: none; }

  /* ── LAYER CONFIG ── */
  .config-panel {
    margin-top: 32px;
    border: 1px solid var(--border);
    background: var(--surface);
    display: none;
  }

  .config-panel.visible { display: block; }

  .config-header {
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .config-header-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .file-badge {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--gold);
    background: var(--gold-glow);
    border: 1px solid var(--gold-dim);
    padding: 3px 10px;
    letter-spacing: 0.08em;
  }

  .config-filename {
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    color: var(--text);
  }

  .config-body { padding: 24px; }

  .config-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }

  .config-tab {
    padding: 10px 20px;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dim);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
  }

  .config-tab.active {
    color: var(--gold);
    border-bottom-color: var(--gold);
  }

  .tab-content { display: none; }
  .tab-content.active { display: block; }

  .field-group { margin-bottom: 20px; }

  .field-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    color: var(--dim);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 8px;
    display: block;
  }

  .field-input,
  .field-textarea {
    width: 100%;
    background: var(--deep);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    padding: 10px 14px;
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
  }

  .field-input:focus,
  .field-textarea:focus { border-color: var(--blue-dim); }

  .field-textarea { min-height: 100px; }

  .layer-toggles {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 24px;
  }

  .layer-toggle {
    padding: 14px 16px;
    border: 1px solid var(--border);
    background: var(--deep);
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .layer-toggle.on {
    border-color: var(--blue-dim);
    background: var(--pulse);
  }

  .toggle-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--muted);
    transition: background 0.2s;
    flex-shrink: 0;
  }

  .layer-toggle.on .toggle-dot { background: var(--blue); }

  .toggle-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--dim);
    letter-spacing: 0.08em;
  }

  .layer-toggle.on .toggle-label { color: var(--text); }

  /* ── EMBED BUTTON ── */
  .embed-btn {
    width: 100%;
    padding: 16px;
    background: var(--gold);
    color: var(--void);
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .embed-btn:hover { background: var(--bright); }

  .embed-btn:disabled {
    background: var(--muted);
    cursor: not-allowed;
  }

  /* ── PROGRESS ── */
  .progress-wrap {
    margin-top: 24px;
    display: none;
  }

  .progress-wrap.visible { display: block; }

  .progress-steps {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .progress-step {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    background: var(--deep);
    border: 1px solid var(--border);
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--muted);
    transition: all 0.3s;
  }

  .progress-step.active {
    border-color: var(--gold-dim);
    color: var(--gold);
    background: var(--gold-glow);
  }

  .progress-step.done {
    border-color: var(--blue-dim);
    color: var(--blue);
    background: var(--pulse);
  }

  .step-icon {
    width: 16px;
    text-align: center;
    font-size: 0.7rem;
  }

  /* ── RESULT ── */
  .result-wrap {
    margin-top: 24px;
    display: none;
  }

  .result-wrap.visible { display: block; }

  .result-box {
    border: 1px solid var(--gold-dim);
    background: var(--gold-glow);
    padding: 24px;
  }

  .result-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.2rem;
    color: var(--bright);
    margin-bottom: 8px;
  }

  .result-sub {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--gold);
    margin-bottom: 20px;
    letter-spacing: 0.05em;
  }

  .result-layers {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 20px;
  }

  .result-layer {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--dim);
  }

  .result-layer::before {
    content: '✓';
    color: var(--gold);
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 24px;
    background: var(--gold);
    color: var(--void);
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }

  .download-btn:hover { background: var(--bright); }

  /* ── HOW IT WORKS ── */
  .how-section {
    padding: 120px 0;
    border-top: 1px solid var(--border);
  }

  .how-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1px;
    background: var(--border);
    margin-top: 60px;
  }

  .how-card {
    background: var(--surface);
    padding: 40px 32px;
  }

  .how-number {
    font-family: 'DM Serif Display', serif;
    font-size: 3rem;
    color: var(--border);
    line-height: 1;
    margin-bottom: 20px;
  }

  .how-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.2rem;
    color: var(--bright);
    margin-bottom: 12px;
  }

  .how-body {
    font-size: 0.88rem;
    color: var(--dim);
    line-height: 1.7;
  }

  /* ── SPEC SECTION ── */
  .spec-section {
    padding: 120px 0;
    border-top: 1px solid var(--border);
  }

  .spec-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-top: 60px;
  }

  .spec-block {
    border: 1px solid var(--border);
    background: var(--surface);
  }

  .spec-header {
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    color: var(--gold);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .spec-code {
    padding: 24px;
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    color: var(--text);
    line-height: 1.8;
    white-space: pre;
    overflow-x: auto;
  }

  .spec-code .c { color: var(--dim); }
  .spec-code .k { color: var(--gold); }
  .spec-code .s { color: var(--blue); }

  /* ── THE PHILOSOPHY (hidden in plain sight) ── */
  .philosophy-section {
    padding: 120px 0;
    border-top: 1px solid var(--border);
  }

  .philosophy-inner {
    max-width: 640px;
  }

  blockquote {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-style: italic;
    color: var(--text);
    line-height: 1.5;
    padding-left: 28px;
    border-left: 2px solid var(--gold);
    margin: 40px 0;
  }

  .philosophy-body {
    font-size: 0.95rem;
    color: var(--dim);
    line-height: 1.8;
  }

  .philosophy-body p { margin-bottom: 20px; }

  /* ── FOOTER ── */
  footer {
    padding: 60px 0 40px;
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 32px;
  }

  .footer-logo {
    font-family: 'DM Serif Display', serif;
    font-size: 1.6rem;
    color: var(--bright);
  }

  .footer-logo span { color: var(--gold); }

  .footer-tagline {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    margin-top: 6px;
  }

  .footer-links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--dim);
    text-decoration: none;
    letter-spacing: 0.08em;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--text); }

  .footer-bottom {
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-copy {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .fade-in { animation: fadeInUp 0.8s both; }
  .fade-in-1 { animation: fadeInUp 0.8s 0.1s both; }
  .fade-in-2 { animation: fadeInUp 0.8s 0.25s both; }
  .fade-in-3 { animation: fadeInUp 0.8s 0.4s both; }
  .fade-in-4 { animation: fadeInUp 0.8s 0.55s both; }

  /* ── VERIFY SECTION ── */
  .verify-section {
    padding: 80px 0;
    border-top: 1px solid var(--border);
  }

  .verify-result {
    margin-top: 20px;
    padding: 20px 24px;
    border: 1px solid var(--border);
    background: var(--surface);
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    color: var(--dim);
    line-height: 1.8;
    display: none;
    white-space: pre-wrap;
  }

  .verify-result.visible { display: block; }
  .verify-result .found { color: var(--gold); }
  .verify-result .clean { color: var(--blue); }

  @media (max-width: 768px) {
    .how-grid { grid-template-columns: 1fr; }
    .spec-grid { grid-template-columns: 1fr; }
    .layer-toggles { grid-template-columns: 1fr; }
    nav { padding: 16px 24px; }
    .nav-links { display: none; }
    .wrap { padding: 0 20px; }
  }
</style>
</head>
<body>

<canvas id="cosmos"></canvas>

<!-- NAV -->
<nav id="nav">
  <div class="nav-logo">&#x1D510;<span>·</span>bius</div>
  <ul class="nav-links">
    <li><a href="#embed">Embed</a></li>
    <li><a href="#how">How It Works</a></li>
    <li><a href="#spec">Spec</a></li>
    <li><a href="#verify">Verify</a></li>
    <li><a href="https://github.com/mkuwandf/synapse" target="_blank">GitHub ↗</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="wrap">
    <div class="hero-inner">
      <div class="hero-tag fade-in">TLD/1.0 — The Full-Spectrum Web Standard</div>
      <h1 class="fade-in-1">One file.<br><em>Two realities.</em></h1>
      <p class="hero-sub fade-in-2">
        Synapse embeds a <strong>machine-readable layer</strong> into any document.
        Humans see what they've always seen.
        AI reads what was always there.
        The open standard for the full-spectrum web.
